generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id                       String    @id @default(uuid()) @db.Uuid
  slug                     String    @unique
  nameEn                   String    @map("name_en")
  nameAr                   String    @map("name_ar")
  campaignNameEn           String?   @map("campaign_name_en")
  campaignNameAr           String?   @map("campaign_name_ar")
  prizeEn                  String?   @map("prize_en")
  prizeAr                  String?   @map("prize_ar")
  bdPerEntry               Decimal   @default(10) @map("bd_per_entry") @db.Decimal(10, 3)
  metaPhoneNumberId        String?   @map("meta_phone_number_id")
  metaAccessTokenEncrypted String?   @map("meta_access_token_encrypted")
  metaTemplateName         String?   @default("campaign_entry_confirmation") @map("meta_template_name")
  metaTemplateLang         String?   @default("ar") @map("meta_template_lang")
  googleSheetId            String?   @map("google_sheet_id")
  createdAt                DateTime? @default(now()) @map("created_at")

  storeUsers       StoreUser[]
  contacts         Contact[]
  receipts         Receipt[]
  raffleEntries    RaffleEntry[]
  customerMessages CustomerMessage[]

  @@map("stores")
}

model UserProfile {
  id           String    @id @default(cuid())
  email        String    @unique
  fullName     String?   @map("full_name")
  passwordHash String?   @map("password_hash") // bcrypt hash for credentials login
  role         String // 'admin' | 'manager' | 'cashier'
  permissions  Json?     @db.JsonB // per-user overrides, e.g. { "canExport": true }
  createdAt    DateTime? @default(now()) @map("created_at")

  storeUsers      StoreUser[]
  cashiedReceipts Receipt[]
  auditLogEntries AuditLog[]

  @@map("user_profiles")
}

model StoreUser {
  storeId String @map("store_id") @db.Uuid
  userId  String @map("user_id")

  store Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storeId, userId])
  @@map("store_users")
}

model Contact {
  id           String    @id @default(uuid()) @db.Uuid
  storeId      String    @map("store_id") @db.Uuid
  name         String
  phone        String // normalized: +<digits>
  totalBd      Decimal   @default(0) @map("total_bd") @db.Decimal(12, 3)
  totalEntries Int       @default(0) @map("total_entries")
  invoiceCount Int       @default(0) @map("invoice_count")
  invoiceIds   String[]  @default([]) @map("invoice_ids")
  lastSeen     DateTime? @default(now()) @map("last_seen")
  createdAt    DateTime? @default(now()) @map("created_at")

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  receipts      Receipt[]
  raffleEntries RaffleEntry[]

  @@unique([storeId, phone])
  @@map("contacts")
}

model Receipt {
  id                 String    @id @default(uuid()) @db.Uuid
  storeId            String    @map("store_id") @db.Uuid
  contactId          String    @map("contact_id") @db.Uuid
  invoiceId          String    @map("invoice_id")
  amount             Decimal   @db.Decimal(12, 3)
  entries            Int
  totalEntriesAtTime Int?      @map("total_entries_at_time")
  cashierNote        String?   @map("cashier_note")
  cashierUserId      String?   @map("cashier_user_id")
  cashierEmail       String?   @map("cashier_email")
  wamid              String?
  messageStatus      String?   @default("pending") @map("message_status") // pending, sent, delivered, read, failed, skipped
  messageError       String?   @map("message_error")
  createdAt          DateTime? @default(now()) @map("created_at")

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  contact       Contact       @relation(fields: [contactId], references: [id])
  cashierUser   UserProfile?  @relation(fields: [cashierUserId], references: [id])
  raffleEntries RaffleEntry[]
  retryQueue    RetryQueue[]

  @@unique([storeId, invoiceId])
  @@index([wamid], map: "idx_receipts_wamid")
  @@index([storeId, createdAt], map: "idx_receipts_store_created")
  @@map("receipts")
}

model RaffleEntry {
  id          String    @id @default(uuid()) @db.Uuid
  storeId     String    @map("store_id") @db.Uuid
  receiptId   String    @map("receipt_id") @db.Uuid
  contactId   String    @map("contact_id") @db.Uuid
  entryNumber Int       @map("entry_number")
  name        String
  phone       String
  invoiceId   String    @map("invoice_id")
  createdAt   DateTime? @default(now()) @map("created_at")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id])

  @@unique([storeId, entryNumber])
  @@index([storeId, entryNumber], map: "idx_raffle_store_number")
  @@map("raffle_entries")
}

model CustomerMessage {
  id          String    @id @default(uuid()) @db.Uuid
  storeId     String?   @map("store_id") @db.Uuid
  fromPhone   String    @map("from_phone")
  messageText String?   @map("message_text")
  messageType String?   @map("message_type")
  wamid       String?
  receivedAt  DateTime? @default(now()) @map("received_at")

  store Store? @relation(fields: [storeId], references: [id])

  @@map("customer_messages")
}

model AuditLog {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String?   @map("user_id")
  action     String
  entityType String?   @map("entity_type")
  entityId   String?   @map("entity_id")
  changes    Json?     @db.JsonB
  createdAt  DateTime? @default(now()) @map("created_at")

  user UserProfile? @relation(fields: [userId], references: [id])

  @@map("audit_log")
}

// Optional: for rate-limit retry queue
model RetryQueue {
  id          String    @id @default(uuid()) @db.Uuid
  receiptId   String    @map("receipt_id") @db.Uuid
  attempts    Int       @default(0)
  lastError   String?   @map("last_error")
  nextRetryAt DateTime? @default(now()) @map("next_retry_at")
  createdAt   DateTime? @default(now()) @map("created_at")

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@map("retry_queue")
}
