# ---------------------------------------------------------------------------
# Database (Neon Postgres)
# ---------------------------------------------------------------------------
# Pooled connection string (used by the app at runtime via the Neon adapter).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Direct (unpooled) connection string — used by Prisma Migrate.
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ---------------------------------------------------------------------------
# Auth (NextAuth / Auth.js)
# ---------------------------------------------------------------------------
# Secret used to sign session JWTs. Generate with:
#   npx auth secret        (or)   openssl rand -base64 33
AUTH_SECRET="your-generated-secret"

# Admin login to create on `npm run db:seed` (optional but recommended).
# Staff sign in with a username; the email is optional contact detail.
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="change-this-strong-password"
SEED_ADMIN_NAME="Site Admin"
SEED_ADMIN_EMAIL=""

# ---------------------------------------------------------------------------
# Google Sheets sync (service account)
# ---------------------------------------------------------------------------
# Each store's sheet is a human-readable VIEW, not a live mirror: a nightly
# cron (scripts/daily-sheet-sync.ts) writes a full snapshot of Contacts / Log /
# Raffle, then pushes current contacts into the store's failover sheet. There
# is no per-scan dual-write.
#
# Setup: enable the Google Sheets API, create a service account, then share
# each store's sheets with the address below as Editor, and paste the sheet IDs
# (from their URLs) into Settings for the store. A store with no Sheet ID is
# skipped.
GOOGLE_SERVICE_ACCOUNT_EMAIL="service-account@project.iam.gserviceaccount.com"
# Keep the literal \n escapes; the app replaces them with real newlines.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# Meta / WhatsApp
# ---------------------------------------------------------------------------
# Shared secret you also configure in the Meta webhook settings.
WEBHOOK_VERIFY_TOKEN="a-long-random-string"

# Meta app secret (App Dashboard → Settings → Basic). Optional but strongly
# recommended: when set, incoming webhook payloads are verified against the
# X-Hub-Signature-256 header, so nobody can POST fake delivery statuses.
META_APP_SECRET=""

# ---------------------------------------------------------------------------
# Encryption (for Meta access tokens stored in the DB)
# ---------------------------------------------------------------------------
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="base64-32-byte-key"

# ---------------------------------------------------------------------------
# Optional: realtime (Pusher)
# ---------------------------------------------------------------------------
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
